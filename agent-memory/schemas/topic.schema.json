{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mlarkin00/agent-memory/schemas/topic.schema.json",
  "title": "Topic frontmatter",
  "description": "YAML frontmatter required on every file under topics/",
  "type": "object",
  "required": ["name", "description", "type", "roles", "valid_from"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case identifier. MUST match the filename stem."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300,
      "description": "One sentence used for fuzzy match at read time."
    },
    "type": {
      "type": "string",
      "enum": ["user", "project", "feedback", "reference"]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "description": "Roles permitted to read this topic."
    },
    "valid_from": {
      "type": "string",
      "format": "date"
    },
    "valid_until": {
      "type": ["string", "null"],
      "format": "date",
      "description": "null or omitted = currently valid."
    },
    "supersedes": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*\\.md$",
      "description": "Filename of the topic this one replaces."
    },
    "user_id": {
      "type": "string",
      "description": "Set when the topic is user-scoped; omit for shared topics."
    }
  }
}
